*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Environment / secrets ─────────────────────────────────────
.env
.env.*
*.env
